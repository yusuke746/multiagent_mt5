# ===================================================
# Multi-Agent MT5 Trading System - 設定ファイル
# ===================================================
# このファイルを .env にコピーして必要事項を記入してください

# --- OpenAI API ---
OPENAI_API_KEY=sk-...

# --- Discord Webhook ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- MT5 接続設定 (デモ口座) ---
MT5_PATH=C:\Program Files\XMTrading MT5\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=password
MT5_SERVER=XMTrading-MT5 3

# --- 監視銘柄 (まずは GOLD のみ、将来追加可能) ---
# カンマ区切りで複数指定: GOLD,USDJPY,EURUSD
SYMBOLS=GOLD

# ===================================================
# TradingAgents 設定
# ===================================================

# アナリスト ON/OFF (すべて true でも OK)
TA_USE_MARKET=true
TA_USE_NEWS=true
TA_USE_SOCIAL=true
TA_USE_FUNDAMENTALS=false  # Gold には株財務データがないため false 推奨

# LLM モデル (OpenAI)
# 精度重視: gpt-4.1 / コスト重視: gpt-4.1-mini
TA_DEEP_MODEL=gpt-4.1
TA_QUICK_MODEL=gpt-4.1-mini

# ディベートラウンド (1=速い, 2=精度↑コスト↑)
TA_MAX_DEBATE_ROUNDS=1
TA_MAX_RISK_ROUNDS=1

# シグナルキャッシュ有効期限 (時間)
TA_SIGNAL_MAX_AGE_HOURS=2.5

# H1 分析間隔 (秒) デフォルト=3600 (1時間)
TA_ANALYSIS_INTERVAL_SEC=3600

# シグナルフリップ時にポジションをクローズするか
TA_EXIT_ON_SIGNAL_FLIP=true
TA_EXIT_ON_SIGNAL_NEUTRAL=false

# ===================================================
# 資金管理
# ===================================================

# 1トレードの最大損失 = 残高の何% (デモは保守的に 1%)
RISK_PER_TRADE=0.01

# 最大ロット数
MAX_LOT=0.5

# 相関グループの最大同時ポジション数
MAX_CORRELATED_POSITIONS=1

# ===================================================
# エントリー SL/TP 設定
# ===================================================

# SL = ATR(M15, 14) × この倍率 (デフォルト)
ENTRY_SL_ATR_MULT=1.5

# GOLD 専用 SL 倍率 (ボラが大きいため大きめに設定)
ENTRY_SL_ATR_MULT_GOLD=2.0

# TP = SL距離 × この倍率 (RR比)
ENTRY_TP_R=2.0

# 再エントリークールダウン (M15バー数)
SYMBOL_REENTRY_COOLDOWN_BARS=3

# ===================================================
# 利益保護
# ===================================================
PROFIT_PROTECTION_ENABLED=true
BREAKEVEN_R=1.0
BREAKEVEN_BUFFER_R=0.10
LOCK_PROFIT_1_TRIGGER_R=1.5
LOCK_PROFIT_1_R=0.50
LOCK_PROFIT_2_TRIGGER_R=2.0
LOCK_PROFIT_2_R=1.00

# ===================================================
# 週末・日次クローズ
# ===================================================
FLAT_BEFORE_WEEKEND_CLOSE_ENABLED=true
FLAT_BEFORE_WEEKEND_CLOSE_LEAD_MINUTES=30
# 日次クローズ (0:00 = 無効)
FLAT_BEFORE_MARKET_CLOSE_ENABLED=false
FLAT_BEFORE_MARKET_CLOSE_HOUR=0
FLAT_BEFORE_MARKET_CLOSE_MINUTE=0
FLAT_BEFORE_MARKET_CLOSE_LEAD_MINUTES=15

# ===================================================
# ニュース監視
# ===================================================
NEWS_CALENDAR_ENABLED=true
NEWS_CALENDAR_INTERVAL_MINUTES=60
NEWS_EVENT_BLOCK_MINUTES=30
NEWS_MONITOR_ENABLED=true
NEWS_MONITOR_INTERVAL_MINUTES=30
NEWS_MONITOR_MODEL=gpt-4.1-nano
NEWS_CACHE_EXPIRE_MINUTES=45
NEWS_BLOCK_ON_MEDIUM=false

# Finnhub API (無料ニュース用、省略可)
FINNHUB_API_KEY=

# ===================================================
# 市場ストレス検知
# ===================================================
MARKET_STRESS_SPREAD_RATIO=3.0
MARKET_STRESS_ATR_RATIO=2.5
MARKET_STRESS_AI_ENABLED=true

# ===================================================
# DBパス (変更不要)
# ===================================================
DB_PATH=trades.db
